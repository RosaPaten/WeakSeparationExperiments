#where I, J are integers
def is_sep(I,J):
  I_new = []
  J_new = []
  for i in I:
    if i not in J:
      I_new.append(i)
  for j in J:
    if j not in I:
      J_new.append(j)

  p = I_new[0]
  q = J_new[0]
  m = abs(p-q)
  for i in I_new:
    for j in J_new:
      if abs(i-j)<m:
        p = i
        q = j
        m = abs(i - j)

  if p<q:
    for i in I:
      if i>p:
        return False
    for j in J:
      if j<q:
        return False
  elif p>q:
    for i in I:
      if i<p:
        return False
    for j in J:
      if j>q:
        return False
  return True

