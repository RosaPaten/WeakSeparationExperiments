#specify a point as a tuple in Z/n\times Z

def integer_mapping(p,n):
  return n*p[0]+p[1]
  
#where I, J are integers
def is_sep(I,J):
  I_new = []
  J_new = []
  for i in I:
    if i not in J:
      I_new.append(i)
  for j in J:
    if j not in I:
      J_new.append(j)

  p = I_new[0]
  q = J_new[0]
  m = abs(p-q)
  for i in I_new:
    for j in J_new:
      if abs(i-j)<m:
        p = i
        q = j
        m = abs(i - j)

  if p<q:
    for i in I:
      if i>p:
        return False
    for j in J:
      if j<q:
        return False
  elif p>q:
    for i in I:
      if i<p:
        return False
    for j in J:
      if j>q:
        return False
  return True

def translate(I,n):
  I_new = []
  for i in I:
    I_new.append(i+n)


def is_trans_sep_int(I,J,n,num):
  J_new = []
  for r in range(-num,num+1):
    J_new = translate(I,r*n)
    if is_sep(I,J_new) == False:
      return False
  return True

def is_trans_sep(I,J,n,num):
  I_new = []
  J_new = []
  for i in I:
    I_new.append(integer_mapping(i,n))
  for j in J:
    J_new.append(integer_mapping(j,n))
  return is_trans_sep_int(I_new,J_new,n,num)
    

  
