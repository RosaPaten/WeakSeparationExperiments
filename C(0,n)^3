###overall idea: map a point in Z/n\times Z to a point in Z. then check weak separability on Z.

#specify a point as a list in Z/n\times Z
import networkx as nx

#maps a point in Z/n\times Z to a point in Z so that can compare position
def integer_mapping(p,n):
  return p[0]+n*p[1]

#does this over an entire list of points
def int_mapping_list(arr,n):
  new = []
  for i in arr:
    new.append(integer_mapping(i,n))
  return new

#where I, J are arrays of integers. checks weak separability
def is_sep(I,J):
  I_new = []
  J_new = []
  for i in I:
    if i not in J:
      I_new.append(i)
  for j in J:
    if j not in I:
      J_new.append(j)
  for i_1 in I_new:
    for i_2 in I_new:
      if i_1<i_2:
        for j_1 in J_new:
          if j_1<i_2 and j_1>i_1:
            for j_2 in J_new:
              if j_2>i_2:
                return False
          elif j_1<i_1:
            for j_2 in J_new:
              if j_2<i_2 and j_2>i_1:
                return False
  return True

def is_cone(p,n):
  int_p = int_mapping_list(p,n)
  int_p.sort()
  #print(int_p)
  if int_p[1]-int_p[0]==1 and int_p[2]-int_p[1]==1:
    return True
  return False

def translate(I,n):
  I_new = []
  for i in I:
    I_new.append(i+n)
  return I_new

def should_stop(I,J):
  i_min = min(I)
  i_max = max(I)
  j_min = min(J)
  j_max = max(J)
  if i_min>j_max or j_min>i_max:
    return True
  return False

def second_too_big(I,J):
  if min(J)>max(I):
    return True
  return False

def second_too_small(I,J):
  if max(J)<min(I):
    return True
  return False

#checks weak separability under 
def is_trans_sep_int(I,J,n):
  J_new = translate(J,0)
  if second_too_big(I,J_new) is True:
    while second_too_small(I,J_new) is False:
      if is_sep(I,J_new) is False:
        return False
      J_new = translate(J_new,-n)
  elif second_too_small(I,J_new) is True:
    while second_too_big(I,J_new) is False:
      if is_sep(I,J_new) is False:
        return False
      J_new = translate(J_new,n)
  else:
    while should_stop(I,J_new) is False:
      if is_sep(I,J_new) == False:
        return False
      J_new = translate(J_new,n)
    J_new = translate(J,0)
    while should_stop(I,J_new) is False:
      if is_sep(I,J_new) == False:
        return False
      J_new = translate(J_new,-n)
  return True

  
