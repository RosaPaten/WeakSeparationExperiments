def is_trans_sep(I,J,n):
  I_new = []
  J_new = []
  for i in I:
    I_new.append(integer_mapping(i,n))
  for j in J:
    J_new.append(integer_mapping(j,n))
  #print(I_new,J_new)
  return is_trans_sep_int(I_new,J_new,n)

def gen_all(n):
  all = []
  for i in range(n):
    p = [[i,0],[i,1],[i,2]]
    all.append(p)
  for j in range(n):
    for i in range(j):
      p = [[i,0],[i,1],[j,0]]
      all.append(p)
      p = [[i,0],[i,1],[j,1]]
      all.append(p)
      p = [[i,0],[i,1],[j,-1]]
      all.append(p)
      p = [[j,0],[j,1],[i,0]]
      all.append(p)
      p = [[j,0],[j,1],[i,1]]
      all.append(p)
      p = [[j,0],[j,1],[i,2]]
      all.append(p)

  for k in range(n):
    for j in range(k):
      for i in range(j):
        p = [[i,0],[j,0],[k,0]]
        if is_cone(p,n) == False:
          all.append(p)
        p = [[i,1],[j,1],[k,0]]
        if is_cone(p,n) == False:
          all.append(p)
        p = [[i,1],[j,0],[k,0]]
        if is_cone(p,n) == False:
          all.append(p)
  return all


def hash(p):
  new = tuple()
  for i in p:
    new= new+((i[0],i[1]),)
  return new



